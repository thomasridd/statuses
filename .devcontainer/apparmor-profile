#include <tunables/global>

profile devcontainer-profile flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/openssl>
  
  # Network access
  network inet stream,
  network inet6 stream,
  network inet dgram,
  network inet6 dgram,
  network unix stream,
  
  # File system access - workspace
  /workspace/** rw,
  /tmp/** rw,
  /home/vscode/.cache/** rw,
  
  # Read-only access to system binaries
  /bin/** rix,
  /usr/bin/** rix,
  /usr/local/bin/** rix,
  /usr/lib/** rm,
  /lib/** rm,
  
  # Node.js and npm specific
  /home/vscode/.npm/** rw,
  /home/vscode/.npm-global/** rw,
  /home/vscode/.config/** rw,
  
  # Deny access to sensitive host paths
  deny /etc/shadow r,
  deny /etc/passwd w,
  deny /etc/sudoers r,
  deny /root/** rw,
  deny /home/*/.ssh/** rw,
  
  # System information (read-only)
  /proc/** r,
  /sys/** r,
  
  # Device access
  /dev/null rw,
  /dev/zero rw,
  /dev/full rw,
  /dev/random r,
  /dev/urandom r,
  /dev/tty rw,
  /dev/pts/* rw,
  
  # Capability restrictions (none beyond default)
  # Dangerous capabilities are already dropped in runArgs
  
  # Signal restrictions
  signal (send) peer=unconfined,
  signal (receive) peer=unconfined,
  
  # PTrace restrictions - deny debugging access
  deny ptrace,
}
